# Cloud Misconfiguration Scanner - Environment Configuration

# Logging
LOG_LEVEL=INFO

# Timeout for network requests (seconds)
REQUEST_TIMEOUT=10

# Scanner Configuration
ENABLE_DNS_DISCOVERY=true
ENABLE_SEARCH_DISCOVERY=true

# Report Settings
REPORT_FORMAT=both
OUTPUT_DIRECTORY=./output

# AWS Settings (optional - if you want authenticated scanning)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Azure Settings (optional)
# AZURE_STORAGE_CONNECTION_STRING=

# Proxy Settings (optional)
# HTTP_PROXY=
# HTTPS_PROXY=
